# App URL (used for OG meta tags; auto-detected on Vercel)
NEXT_PUBLIC_APP_URL=

# Supabase
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile (bot protection)
# Get keys at https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# For local development without Turnstile, leave these empty.
# The app will skip verification when TURNSTILE_SECRET_KEY is not set.

# Cookie signing (for PIN verification HMAC)
# Generate with: openssl rand -hex 32
COOKIE_SECRET=

# Stripe (party creation payment)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cron job authorization
# Generate with: openssl rand -hex 32
# Must also be set in your Vercel project environment variables
CRON_SECRET=

# Resend (transactional emails)
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=
# Sender address — must match a verified domain in Resend
EMAIL_FROM=sideroom <noreply@mail.sideroom.link>
